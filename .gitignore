# =========================
# Конфиденциальные данные
# =========================
# Игнорируем все .env файлы с секретами
.env
.env.*
# Но ИСКЛЮЧАЕМ из игнора шаблон, он должен улететь в Git
!.env.example

# =========================
# Python и виртуальные окружения
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/

# =========================
# Сборка и пакеты
# =========================
build/
dist/
wheels/
*.egg-info/
.eggs/

# =========================
# Кэши линтеров и типизации (Ruff, Pyright)
# =========================
.ruff_cache/
.pyright/
.mypy_cache/

# =========================
# Тестирование (pytest)
# =========================
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# =========================
# IDE и редакторы (VS Code)
# =========================
.vscode/*
# Разрешаем коммитить общие настройки проекта для команды (по желанию)
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp

# =========================
# Системные файлы (Windows / macOS)
# =========================
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# =========================
# Логи и временные файлы
# =========================
*.log
*.bak
*.tmp